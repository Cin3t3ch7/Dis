# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# Telegram Bot Token
BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE

# Super Admin User IDs (comma-separated)
SUPER_ADMIN_IDS=123456789,987654321

# Web Security - GENERATE SECURE KEYS (e.g., using `openssl rand -base64 32`)
SECRET_KEY=YOUR_GENERATED_SECRET_KEY
ENCRYPTION_KEY=YOUR_GENERATED_ENCRYPTION_KEY # Must be a valid 32-byte base64 Fernet key

# Application Settings
LOG_LEVEL=INFO
PRODUCTION=false
PORT=8000

# Session Configuration
SESSION_LIFETIME_HOURS=24
MAX_CONCURRENT_SESSIONS=3

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
